{
  "name": "stateflow",
  "displayName": "StateFlow",
  "description": "Deterministic context synchronization between IDE and browser-based LLMs via clipboard.",
  "version": "0.0.1",
  "publisher": "drishti-aggarwal",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-aggarwal/StateFlow"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stateflow.syncRepo",
        "title": "StateFlow: Sync Repo → Chat"
      },

      {
        "command": "stateflow.errorContext",
        "title": "StateFlow: Error Context → Chat"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
